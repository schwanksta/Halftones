{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Halftones",
  "version": "0.7.1",
  "identifier": "com.schwank.halftones",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Halftones",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["halftones"],
        "name": "Halftones Project",
        "role": "Editor",
        "mimeType": "application/x-halftones"
      },
      {
        "ext": ["png"],
        "name": "PNG Image",
        "role": "Viewer",
        "mimeType": "image/png"
      },
      {
        "ext": ["jpg", "jpeg"],
        "name": "JPEG Image",
        "role": "Viewer",
        "mimeType": "image/jpeg"
      },
      {
        "ext": ["webp"],
        "name": "WebP Image",
        "role": "Viewer",
        "mimeType": "image/webp"
      }
    ]
  }
}
